<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <Authorizing>
                    <div style="height: 100vh; display: flex; align-items: center; justify-content: center; background: #FAFAFA; flex-direction: column;">
                         <div style="width: 60px; height: 60px; border: 5px solid #E8F5E9; border-top: 5px solid #1B5E20; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                         <div style="color: #1B5E20; font-weight: bold; font-family: Roboto; margin-top: 20px;">Vérification de la session...</div>
                         <style>
                             @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
                         </style>
                    </div>
                </Authorizing>
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Error">Vous n'êtes pas autorisé à accéder à cette page.</MudAlert>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Non trouvé</PageTitle>
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <p role="alert">Désolé, il n'y a rien à cette adresse.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
