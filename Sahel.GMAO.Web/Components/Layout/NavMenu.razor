@using Sahel.GMAO.Core.Constants
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<MudNavMenu>
    <AuthorizeView>
        <Authorized>
            @if (context.User.IsInRole(AppRoles.DSI))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-3 mb-1">GESTION</MudText>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Tableau de Bord</MudNavLink>
                <MudNavLink Href="/demandes" Icon="@Icons.Material.Filled.Assignment">Demandes de Travail</MudNavLink>
                <MudNavLink Href="/mes-taches" Icon="@Icons.Material.Filled.BuildCircle">Exécution DT</MudNavLink>
                <MudNavLink Href="/equipements" Icon="@Icons.Material.Filled.PrecisionManufacturing">Équipements</MudNavLink>
                
                <MudNavGroup Title="Planning" Icon="@Icons.Material.Filled.Event" Expanded="false">
                    <MudNavLink Href="/planning/preventif" Icon="@Icons.Material.Filled.CalendarMonth">Prévisionnel</MudNavLink>
                    <MudNavLink Href="/fiches-entretien" Icon="@Icons.Material.Filled.AssignmentTurnedIn">Exécution Fiches</MudNavLink>
                    <MudNavLink Href="/planning/visites" Icon="@Icons.Material.Filled.FactCheck">Visites Périodique</MudNavLink>
                </MudNavGroup>
                
                <MudNavLink Href="/stock" Icon="@Icons.Material.Filled.Inventory">Stock PDR</MudNavLink>
                <MudNavLink Href="/fabrication" Icon="@Icons.Material.Filled.Build">Fabrication</MudNavLink>
                <MudNavLink Href="/consignations" Icon="@Icons.Material.Filled.Lock">Consignations</MudNavLink>
                <MudNavLink Href="/travaux" Icon="@Icons.Material.Filled.Task">Travaux</MudNavLink>
                
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-1 mb-1">CONFIGURATION</MudText>
                <MudNavLink Href="/utilisateurs" Icon="@Icons.Material.Filled.People">Utilisateurs</MudNavLink>
                <MudNavLink Href="/parametres" Icon="@Icons.Material.Filled.Settings">Paramètres</MudNavLink>
            }
            else if (context.User.IsInRole(AppRoles.Executant))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-3 mb-1">MAINTENANCE</MudText>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.PlaylistAddCheck">Mes Tâches</MudNavLink>
                <MudNavLink Href="/mes-taches" Icon="@Icons.Material.Filled.BuildCircle">Exécution DT</MudNavLink>
                <MudNavLink Href="/demandes" Icon="@Icons.Material.Filled.Assignment">Toutes les DT</MudNavLink>
                <MudNavLink Href="/consignations" Icon="@Icons.Material.Filled.Lock">Consignations</MudNavLink>
                <MudNavLink Href="/fiches-entretien" Icon="@Icons.Material.Filled.AssignmentTurnedIn">Fiches Entretien</MudNavLink>
                <MudNavLink Href="/equipements" Icon="@Icons.Material.Filled.PrecisionManufacturing">Équipements</MudNavLink>
            }
            else if (context.User.IsInRole(AppRoles.Demandeur))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-3 mb-1">ACCÈS DIRECT</MudText>
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Tableau de Bord</MudNavLink>
                <MudNavLink Href="/demandes" Icon="@Icons.Material.Filled.Assignment">Mes Demandes (DT)</MudNavLink>
            }
            
            @{
                var isDSI = context.User.IsInRole(AppRoles.DSI);
                var isExecutant = context.User.IsInRole(AppRoles.Executant);
                var isDemandeur = context.User.IsInRole(AppRoles.Demandeur);

                if (!isDSI && !isExecutant && !isDemandeur)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mx-4 my-2">
                        Rôle inconnu. <MudLink Color="Color.Inherit" Underline="Underline.Always" OnClick="Logout">Déconnectez-vous</MudLink> pour rafraîchir vos accès.
                    </MudAlert>
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Tableau de Bord (Limité)</MudNavLink>
                }
            }
            
            <MudNavLink Href="/notifications" Icon="@Icons.Material.Filled.Notifications">Notifications</MudNavLink>
        </Authorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private async Task Logout()
    {
        var provider = (Sahel.GMAO.Web.Auth.CustomAuthenticationStateProvider)AuthStateProvider;
        await provider.MarkUserAsLoggedOut();
        NavManager.NavigateTo("/login", true);
    }
}
