@inherits LayoutComponentBase
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="ml-3 font-weight-bold">SAHEL GMAO</MudText>
        
        <NavMenu />
        
        <MudSpacer />
        
        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <div class="pa-3">
                        <MudText Typo="Typo.body2">@context.User.FindFirst("FullName")?.Value</MudText>
                        <MudText Typo="Typo.caption">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</MudText>
                    </div>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Déconnexion</MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Connexion</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudMainContent Class="d-flex flex-column" Style="min-height: 100vh;">
        <div class="flex-grow-1">
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4 pt-4">
                @Body
            </MudContainer>
        </div>
    </MudMainContent>
    <AppFooter />
</MudLayout>

@implements IDisposable

@code {
    protected override void OnInitialized()
    {
        NavManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= HandleLocationChanged;
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1B5E20", // Deep green
            AppbarBackground = "#1B5E20",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#000000",
            PrimaryContrastText = "#FFFFFF",
            Secondary = "#FFB300" // More visible Amber/Gold accent
        }
    };

    private async Task Logout()
    {
        var provider = (Sahel.GMAO.Web.Auth.CustomAuthenticationStateProvider)AuthStateProvider;
        await provider.MarkUserAsLoggedOut();
        NavManager.NavigateTo("/Account/Logout", true);
    }
}
