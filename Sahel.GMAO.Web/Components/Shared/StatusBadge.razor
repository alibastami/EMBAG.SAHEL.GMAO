@using Sahel.GMAO.Core.Enums

<MudChip T="string" Color="@GetColor()" Size="Size.Medium" Variant="Variant.Filled" Class="font-weight-bold px-4">
    @GetLabel()
</MudChip>

@code {
    [Parameter] public StatutDT Statut { get; set; }

    private Color GetColor() => Statut switch
    {
        StatutDT.EnAttente => Color.Warning,   // Step 1: DI
        StatutDT.EnCours => Color.Info,        // Step 2: OT
        StatutDT.Terminee => Color.Success,    // Step 3: Done
        StatutDT.Cloturee => Color.Primary,    // Step 4: Closed
        StatutDT.Annulee => Color.Error,
        _ => Color.Default
    };

    private string GetLabel() => Statut switch
    {
        StatutDT.EnAttente => "1. DI Émise",
        StatutDT.EnCours => "2. OT en Cours",
        StatutDT.Terminee => "3. Intervention Terminée",
        StatutDT.Cloturee => "4. Dossier Clôturé",
        StatutDT.Annulee => "Annulée",
        _ => Statut.ToString()
    };
}
