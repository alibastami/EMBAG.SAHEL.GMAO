@page "/demandes/{id:int}"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Enums
@using Sahel.GMAO.Web.Components.Shared
@inject IDtService DtService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavManager.NavigateTo("/demandes"))" Class="mr-2" />
        <MudText Typo="Typo.h4" Class="font-weight-bold" Color="Color.Primary">
            Détails de la DT : @(_dt?.NumeroDT ?? "Chargement...")
        </MudText>
        <MudSpacer />
        @if (_dt != null)
        {
            <StatusBadge Statut="@_dt.Statut" />
        }
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center align-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_dt == null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">
            Désolé, cette demande de travail est introuvable.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <!-- Travail Demandé (On Top) -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-warning">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Warning" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Assignment" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Travail Demandé</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudPaper Elevation="0" Class="pa-4 bg-light rounded-lg">
                            <MudText Typo="Typo.h6" Class="font-weight-bold" Style="white-space: pre-wrap; font-size: 1.3rem;">@_dt.TravailDemande</MudText>
                        </MudPaper>
                        
                        @if (!string.IsNullOrEmpty(_dt.InstructionsPreparation))
                        {
                            <div class="mt-4">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1" Color="Color.Warning">Instructions de Préparation :</MudText>
                                <MudText Typo="Typo.body1" Class="italic font-weight-bold">@_dt.InstructionsPreparation</MudText>
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Informations Générales & Coûts -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-primary">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Info" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Informations Générales</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Style="overflow-x: auto;" Dense="true" Hover="true" Elevation="0">
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold" style="width: 40%;">N° DT</td>
                                            <td><MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">@_dt.NumeroDT</MudChip></td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Date d'émission</td>
                                            <td>@_dt.DateEmission.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Demandeur</td>
                                            <td>@_dt.Demandeur?.FullName (@_dt.Demandeur?.Username)</td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Style="overflow-x: auto;" Dense="true" Hover="true" Elevation="0">
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold" style="width: 40%;">Équipement</td>
                                            <td>
                                                <MudLink href="@($"/equipements/{_dt.EquipementId}")" Underline="Underline.Hover">
                                                    <b>@_dt.Equipement?.Code</b> - @_dt.Equipement?.Designation
                                                </MudLink>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Organe / Partie</td>
                                            <td>@_dt.OrganePartie</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Spécialité</td>
                                            <td><MudChip T="string" Color="Color.Info" Size="Size.Small">@_dt.SpecialiteRequise</MudChip></td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            @if (_userRole == "DSI")
                            {
                                <MudItem xs="12" md="4">
                                    <MudPaper Elevation="0" Class="pa-4 rounded-lg d-flex flex-column align-center justify-center border-2 border-dashed border-primary" Style="height: 100%;">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="text-center">COÛT TOTAL DE L'OPÉRATION</MudText>
                                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@_dt.TotalCoutOperation.ToString("N2") DA</MudText>
                                        <div class="d-flex gap-4 mt-2">
                                            <MudTooltip Text="Pièces">
                                                <MudText Typo="Typo.caption">PDR: @_dt.TotalCoutPieces.ToString("N0") DA</MudText>
                                            </MudTooltip>
                                            <MudTooltip Text="Main d'oeuvre">
                                                <MudText Typo="Typo.caption">MO: @_dt.TotalCoutMainOeuvre.ToString("N0") DA</MudText>
                                            </MudTooltip>
                                        </div>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Exécution et Pointage -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-success">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Success" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Build" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Détails de l'Exécution</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                             @if (_dt.Statut != StatutDT.Cloturee)
                             {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => NavManager.NavigateTo($"/mes-taches/{_dt.Id}"))">
                                    Mettre à jour
                                </MudButton>
                             }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudText Typo="Typo.subtitle2" Color="Color.Success">Travail Exécuté</MudText>
                                <MudText Typo="Typo.body1" Class="mb-4">@(string.IsNullOrEmpty(_dt.TravailExecute) ? "Pas encore renseigné" : _dt.TravailExecute)</MudText>
                                
                                <MudText Typo="Typo.subtitle2" Color="Color.Success">Période d'Intervention</MudText>
                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.DateRange">@(_dt.DateExecutionDebut?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</MudChip>
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.DateRange">@(_dt.DateExecutionFin?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</MudChip>
                                </div>
                                
                                <MudText Typo="Typo.subtitle2" Color="Color.Success">Arrêt Production</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Error">@_dt.DureeArretProductionHeures H</MudText>
                            </MudItem>
                            
                            <MudItem xs="12" md="8">
                                <MudTabs Elevation="0" Outlined="true" Rounded="true" Color="Color.Success" ApplyEffectsToContainer="true" PanelClass="pa-4">
                                    <MudTabPanel Text="Journal d'Intervention" Icon="@Icons.Material.Filled.History">
                                        @if (_dt.JournalInterventions == null || !_dt.JournalInterventions.Any())
                                        {
                                            <MudAlert Severity="Severity.Normal" Dense="true">Aucun historique d'intervention.</MudAlert>
                                        }
                                        else
                                        {
                                            <div style="max-height: 300px; overflow-y: auto;">
                                                <MudTimeline TimelinePosition="TimelinePosition.Start" Dense="true">
                                                    @foreach (var entry in _dt.JournalInterventions.OrderByDescending(e => e.DateIntervention))
                                                    {
                                                        <MudTimelineItem Color="Color.Info" Size="Size.Small">
                                                            <ItemContent>
                                                                <MudPaper Elevation="0" Class="pa-2 rounded-lg border">
                                                                    <div class="d-flex justify-space-between align-center mb-1">
                                                                        <MudText Typo="Typo.subtitle2">@entry.Intervenant?.FullName</MudText>
                                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@entry.DateIntervention.ToString("dd/MM HH:mm")</MudText>
                                                                    </div>
                                                                    <MudText Typo="Typo.body2">@entry.TravailExecute</MudText>
                                                                    <div class="d-flex gap-2 mt-1">
                                                                        @if (entry.DureeHeures > 0)
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@entry.DureeHeures H</MudChip>
                                                                        }
                                                                        @if (entry.ArretProductionHeures > 0)
                                                                        {
                                                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text">@entry.ArretProductionHeures H Arrêt</MudChip>
                                                                        }
                                                                    </div>
                                                                </MudPaper>
                                                            </ItemContent>
                                                        </MudTimelineItem>
                                                    }
                                                </MudTimeline>
                                            </div>
                                        }
                                    </MudTabPanel>
                                    <MudTabPanel Text="Intervenants" Icon="@Icons.Material.Filled.People">
                                        @if (_dt.Intervenants == null || !_dt.Intervenants.Any())
                                        {
                                            <MudAlert Severity="Severity.Normal" Dense="true">Aucun intervenant assigné.</MudAlert>
                                        }
                                        else
                                        {
                                            <MudTable Items="@_dt.Intervenants" Dense="true" Hover="true" Elevation="0" Class="rounded-lg border">
                                                <HeaderContent>
                                                    <MudTh>Nom</MudTh>
                                                    <MudTh>Qualification</MudTh>
                                                    <MudTh>Heures</MudTh>
                                                    @if (_userRole == "DSI")
                                                    {
                                                        <MudTh>Taux</MudTh>
                                                        <MudTh>Total</MudTh>
                                                    }
                                                </HeaderContent>
                                                <RowTemplate>
                                                    <MudTd DataLabel="Nom">@context.Intervenant?.FullName</MudTd>
                                                    <MudTd DataLabel="Qualification">@context.Qualification</MudTd>
                                                    <MudTd DataLabel="Heures">@context.HeuresTravaillees H</MudTd>
                                                    @if (_userRole == "DSI")
                                                    {
                                                        <MudTd DataLabel="Taux">@context.TauxHoraire.ToString("N0")</MudTd>
                                                        <MudTd DataLabel="Total">
                                                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">@(( (decimal)context.HeuresTravaillees * context.TauxHoraire).ToString("N2")) DA</MudChip>
                                                        </MudTd>
                                                    }
                                                </RowTemplate>
                                            </MudTable>
                                        }
                                    </MudTabPanel>
                                </MudTabs>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Pièces de Rechange -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-info">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Info" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Settings" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Pièces de Rechange (PDR)</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (_dt.Statut != StatutDT.Cloturee)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.AddShoppingCart" OnClick="OpenAddPdrDialog">
                                    Consommer PDR
                                </MudButton>
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_dt.Consommables == null || !_dt.Consommables.Any())
                        {
                            <MudAlert Severity="Severity.Info">Aucune pièce de rechange consommée pour cette DT.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="@_dt.Consommables" Dense="true" Hover="true" Elevation="0" Class="rounded-lg border">
                                <HeaderContent>
                                    <MudTh>Désignation</MudTh>
                                    <MudTh>Quantité</MudTh>
                                    @if (_userRole == "DSI")
                                    {
                                        <MudTh>P.U (DA)</MudTh>
                                        <MudTh>Total (DA)</MudTh>
                                    }
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Désignation">
                                        <MudText Typo="Typo.body2"><b>@context.ArticlePdr?.CodeArticle</b></MudText>
                                        <MudText Typo="Typo.caption">@context.ArticlePdr?.Designation</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="Quantité">@context.Quantite @context.ArticlePdr?.Unite</MudTd>
                                    @if (_userRole == "DSI")
                                    {
                                        <MudTd DataLabel="P.U (DA)">@context.PrixUnitaireApplique.ToString("N2")</MudTd>
                                        <MudTd DataLabel="Total (DA)">
                                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">@(((decimal)context.Quantite * context.PrixUnitaireApplique).ToString("N2")) DA</MudChip>
                                        </MudTd>
                                    }
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<style>
    .border-l-4 { border-left-width: 4px !important; }
    .border-primary { border-left-color: var(--mud-palette-primary) !important; }
    .border-secondary { border-left-color: var(--mud-palette-secondary) !important; }
    .border-success { border-left-color: var(--mud-palette-success) !important; }
    .border-info { border-left-color: var(--mud-palette-info) !important; }
    .bg-light { background-color: var(--mud-palette-background-grey) !important; }
    .italic { font-style: italic; }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private DemandeTravail? _dt;
    private bool _loading = true;
    private string _userRole = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _dt = await DtService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddPdrDialog()
    {
        var parameters = new DialogParameters { ["DtId"] = Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddConsommableDialog>("Consommer PDR", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }
}
