@page "/demandes/{id:int}"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Enums
@using Sahel.GMAO.Core.Constants
@using Sahel.GMAO.Web.Components.Shared
@inject IDtService DtService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 pb-8">
    <div class="d-flex align-center mb-6">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => NavManager.NavigateTo("/demandes"))" Class="mr-2" />
        <MudText Typo="Typo.h4" Class="font-weight-bold" Color="Color.Primary">
            Intervention : @(_dt?.NumeroDT ?? "Chargement...")
        </MudText>
        <MudSpacer />
        @if (_dt != null)
        {
            <div class="d-flex flex-column align-end">
                <StatusBadge Statut="@_dt.Statut" />
                <MudText Typo="Typo.caption" Class="mt-1">Flux : Production → BM → Maintenance</MudText>
            </div>
        }
    </div>

    @if (_dt != null)
    {
        <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-xl bg-light-gradient border">
            <MudGrid Justify="Justify.Center">
                <MudItem xs="3" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="@(_dt.Statut >= StatutDT.EnAttente ? Color.Warning : Color.Default)" Size="Size.Large" />
                    <MudText Typo="Typo.caption" Class="d-block font-weight-bold">1. Émission DI</MudText>
                </MudItem>
                <MudItem xs="3" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Color="@(_dt.Statut >= StatutDT.EnCours ? Color.Info : Color.Default)" Size="Size.Large" />
                    <MudText Typo="Typo.caption" Class="d-block font-weight-bold">2. Création OT</MudText>
                </MudItem>
                <MudItem xs="3" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Build" Color="@(_dt.Statut >= StatutDT.Terminee ? Color.Success : Color.Default)" Size="Size.Large" />
                    <MudText Typo="Typo.caption" Class="d-block font-weight-bold">3. Exécution</MudText>
                </MudItem>
                <MudItem xs="3" Class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Verified" Color="@(_dt.Statut >= StatutDT.Cloturee ? Color.Primary : Color.Default)" Size="Size.Large" />
                    <MudText Typo="Typo.caption" Class="d-block font-weight-bold">4. Clôture</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    @if (_loading)
    {
        <div class="d-flex justify-center align-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else if (_dt == null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">
            Désolé, cette demande de travail est introuvable.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <!-- Travail Demandé (On Top) -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-warning">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Warning" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Assignment" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Travail Demandé</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudPaper Elevation="0" Class="pa-4 bg-light rounded-lg">
                            <MudText Typo="Typo.h6" Class="font-weight-bold" Style="white-space: pre-wrap; font-size: 1.3rem;">@_dt.TravailDemande</MudText>
                        </MudPaper>
                        
                        @if (!string.IsNullOrEmpty(_dt.InstructionsPreparation))
                        {
                            <div class="mt-4">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1" Color="Color.Warning">Instructions de Préparation :</MudText>
                                <MudText Typo="Typo.body1" Class="italic font-weight-bold">@_dt.InstructionsPreparation</MudText>
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Informations Générales & Coûts -->
            <MudItem xs="12">
                <MudCard Elevation="3" Class="rounded-lg border-l-4 border-primary">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Info" /></MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Informations Générales</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Style="overflow-x: auto;" Dense="true" Hover="true" Elevation="0">
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold" style="width: 40%;">N° DT</td>
                                            <td><MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">@_dt.NumeroDT</MudChip></td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Date d'émission</td>
                                            <td>@_dt.DateEmission.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Émis par (Production)</td>
                                            <td>@_dt.Demandeur?.FullName (@_dt.Demandeur?.Username)</td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSimpleTable Style="overflow-x: auto;" Dense="true" Hover="true" Elevation="0">
                                    <tbody>
                                        <tr>
                                            <td class="font-weight-bold" style="width: 40%;">Équipement</td>
                                            <td>
                                                <MudLink href="@($"/equipements/{_dt.EquipementId}")" Underline="Underline.Hover">
                                                    <b>@_dt.Equipement?.Code</b> - @_dt.Equipement?.Designation
                                                </MudLink>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Organe / Partie</td>
                                            <td>@_dt.OrganePartie</td>
                                        </tr>
                                        <tr>
                                            <td class="font-weight-bold">Spécialité</td>
                                            <td><MudChip T="string" Color="Color.Info" Size="Size.Small">@_dt.SpecialiteRequise</MudChip></td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </MudItem>
                            @if (_userRole == "DSI")
                            {
                                <MudItem xs="12" md="4">
                                    <MudPaper Elevation="0" Class="pa-4 rounded-lg d-flex flex-column align-center justify-center border-2 border-dashed border-primary" Style="height: 100%;">
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="text-center">COÛT TOTAL DE L'OPÉRATION</MudText>
                                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@_dt.TotalCoutOperation.ToString("N2") DA</MudText>
                                        <div class="d-flex gap-4 mt-2">
                                            <MudTooltip Text="Pièces">
                                                <MudText Typo="Typo.caption">PDR: @_dt.TotalCoutPieces.ToString("N0") DA</MudText>
                                            </MudTooltip>
                                            <MudTooltip Text="Main d'oeuvre">
                                                <MudText Typo="Typo.caption">MO: @_dt.TotalCoutMainOeuvre.ToString("N0") DA</MudText>
                                            </MudTooltip>
                                        </div>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Exécution & Suivi Technique (Merged Card) -->
            @if (_userRole != AppRoles.Demandeur)
            {
                <MudItem xs="12">
                    <MudCard Elevation="3" Class="rounded-lg border-l-4 border-success">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar Color="Color.Success" Variant="Variant.Filled"><MudIcon Icon="@Icons.Material.Filled.Build" /></MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Exécution & Suivi Technique</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                 @if (_userRole != AppRoles.BM && _dt.Statut != StatutDT.Cloturee)
                                 {
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => NavManager.NavigateTo($"/mes-taches/{_dt.Id}"))" Class="mr-2">
                                        Mettre à jour
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.AddShoppingCart" OnClick="OpenAddPdrDialog">
                                        Consommer PDR
                                    </MudButton>
                                 }
                                 @if ((_userRole == AppRoles.BM || _userRole == AppRoles.DSI) && (_dt.Statut == StatutDT.EnAttente || _dt.Statut == StatutDT.EnCours))
                                 {
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="OpenAssignDialog" Class="mr-2">
                                        Gérer Intervenants / OT
                                    </MudButton>
                                 }
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <!-- Horizontal Summary Line -->
                            <MudGrid Class="mb-4 pa-2 rounded bg-light border">
                                <MudItem xs="12" md="5">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Success">Travail Exécuté</MudText>
                                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(_dt.TravailExecute) ? "Pas encore renseigné" : _dt.TravailExecute)</MudText>
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Success">Période d'Intervention</MudText>
                                    <div class="d-flex align-center gap-1">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@(_dt.DateExecutionDebut?.ToString("dd/MM HH:mm") ?? "N/A")</MudChip>
                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@(_dt.DateExecutionFin?.ToString("dd/MM HH:mm") ?? "N/A")</MudChip>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" md="3">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Success">Arrêt Production</MudText>
                                    <MudText Typo="Typo.h6" Color="Color.Error">@_dt.DureeArretProductionHeures H</MudText>
                                </MudItem>
                            </MudGrid>

                            <MudGrid>
                                <!-- Interventions Table -->
                                <MudItem xs="12" md="7">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Journal & Équipe d'Intervention</MudText>
                                    @if (_dt.JournalInterventions == null || !_dt.JournalInterventions.Any())
                                    {
                                        <MudAlert Severity="Severity.Normal" Dense="true" Class="mb-4">Aucun historique.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudTable Items="@_dt.JournalInterventions" Dense="true" Hover="true" Bordered="true" Elevation="0" Class="mb-4">
                                            <HeaderContent>
                                                <MudTh>Date</MudTh>
                                                <MudTh>Intervenant</MudTh>
                                                <MudTh>Travail</MudTh>
                                                <MudTh>Durée</MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd>@context.DateIntervention.ToString("dd/MM HH:mm")</MudTd>
                                                <MudTd><b>@context.Intervenant?.FullName</b></MudTd>
                                                <MudTd>@context.TravailExecute</MudTd>
                                                <MudTd>@context.DureeHeures H</MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                    }
                                </MudItem>

                                <!-- PDR Table -->
                                <MudItem xs="12" md="5">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Pièces de Rechange Consommées</MudText>
                                    @if (_dt.Consommables == null || !_dt.Consommables.Any())
                                    {
                                        <MudAlert Severity="Severity.Normal" Dense="true">Aucune pièce.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudTable Items="@_dt.Consommables" Dense="true" Hover="true" Bordered="true" Elevation="0">
                                            <HeaderContent>
                                                <MudTh>Code / Désignation</MudTh>
                                                <MudTh>Qté</MudTh>
                                                @if (_userRole == "DSI")
                                                {
                                                    <MudTh>Total</MudTh>
                                                }
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd>
                                                    <b>@context.ArticlePdr?.CodeArticle</b><br/>
                                                    <MudText Typo="Typo.caption">@context.ArticlePdr?.Designation</MudText>
                                                </MudTd>
                                                <MudTd>@context.Quantite @context.ArticlePdr?.Unite</MudTd>
                                                @if (_userRole == "DSI")
                                                {
                                                    <MudTd>@(((decimal)context.Quantite * context.PrixUnitaireApplique).ToString("N0"))</MudTd>
                                                }
                                            </RowTemplate>
                                        </MudTable>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

<style>
    .border-l-4 { border-left-width: 4px !important; }
    .border-primary { border-left-color: var(--mud-palette-primary) !important; }
    .border-secondary { border-left-color: var(--mud-palette-secondary) !important; }
    .border-success { border-left-color: var(--mud-palette-success) !important; }
    .border-info { border-left-color: var(--mud-palette-info) !important; }
    .bg-light { background-color: var(--mud-palette-background-grey) !important; }
    .bg-light-gradient { background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); }
    .italic { font-style: italic; }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private DemandeTravail? _dt;
    private bool _loading = true;
    private string _userRole = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _dt = await DtService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddPdrDialog()
    {
        var parameters = new DialogParameters { ["DtId"] = Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddConsommableDialog>("Consommer PDR", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }

    private async Task OpenAssignDialog()
    {
        var parameters = new DialogParameters { ["Dt"] = _dt };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AssignationDTDialog>("Assigner / Créer OT", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }
}
