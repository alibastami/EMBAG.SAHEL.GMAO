@page "/stock"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@inject IStockService StockService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPdfService PdfService
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "DSI")]

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold" Color="Color.Primary">Stock Pièces de Rechange (PDR)</MudText>

<MudDataGrid Items="@_articles" Filterable="true" QuickFilter="@_quickFilter" Hover="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">État de Stock</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OnAddArticle" Class="mr-4">Ajouter un Article</MudButton>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Visibility" Color="Color.Secondary" OnClick="ViewStockPdf" Class="mr-4">Voir État Stock (PDF)</MudButton>
        <MudTextField @bind-Value="_searchString" Placeholder="Rechercher (Code, Désignation...)" Adornment="Adornment.Start" Immediate="true"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.CodeArticle" Title="Code" />
        <PropertyColumn Property="x => x.ReferenceConstructeur" Title="Réf. Constructeur" />
        <PropertyColumn Property="x => x.Designation" Title="Désignation" />
        <PropertyColumn Property="x => x.Unite" Title="Unité" />
        <PropertyColumn Property="x => x.QuantiteEnStock" Title="Stock Actuel">
            <CellTemplate>
                <MudText Color="@(context.Item.QuantiteEnStock <= context.Item.SeuilAlerte ? Color.Error : Color.Default)" Class="@(context.Item.QuantiteEnStock <= context.Item.SeuilAlerte ? "font-weight-bold" : "")">
                    @context.Item.QuantiteEnStock @context.Item.Unite
                    @if (context.Item.QuantiteEnStock <= context.Item.SeuilAlerte)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="ml-2 mb-n1" />
                    }
                </MudText>
            </CellTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.SeuilAlerte" Title="Seuil Alerte" />
        <PropertyColumn Property="x => x.PrixUnitaire" Title="P.U (DA)">
            <CellTemplate>
                @context.Item.PrixUnitaire.ToString("N2")
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Valeur Totale">
            <CellTemplate>
                @(( (decimal)context.Item.QuantiteEnStock * context.Item.PrixUnitaire ).ToString("N2")) DA
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn CellClass="d-flex justify-end">
            <CellTemplate>
                <MudTooltip Text="Modifier">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OnEditArticle(context.Item))" />
                </MudTooltip>
                <MudTooltip Text="Supprimer">
                    <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => OnDeleteArticle(context.Item))" />
                </MudTooltip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="ArticlePdr" />
    </PagerContent>
</MudDataGrid>

@code {
    private List<ArticlePdr> _articles = new();
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _articles = await StockService.GetAllAsync();
    }

    private async Task OnAddArticle()
    {
        var parameters = new DialogParameters<AddEditArticleDialog> { { x => x.Article, new ArticlePdr() }, { x => x.IsEdit, false } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddEditArticleDialog>("Nouveau PDR", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var article = (ArticlePdr)result.Data!;
            await StockService.CreateArticleAsync(article);
            Snackbar.Add("Nouvel article ajouté au stock", Severity.Success);
            await LoadData();
        }
    }

    private async Task OnEditArticle(ArticlePdr article)
    {
        // Clone the article for editing
        var articleClone = new ArticlePdr
        {
            Id = article.Id,
            CodeArticle = article.CodeArticle,
            Designation = article.Designation,
            ReferenceConstructeur = article.ReferenceConstructeur,
            Unite = article.Unite,
            QuantiteEnStock = article.QuantiteEnStock,
            SeuilAlerte = article.SeuilAlerte,
            PrixUnitaire = article.PrixUnitaire
        };

        var parameters = new DialogParameters<AddEditArticleDialog> { { x => x.Article, articleClone }, { x => x.IsEdit, true } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddEditArticleDialog>("Modifier PDR", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var updatedArticle = (ArticlePdr)result.Data!;
            await StockService.UpdateArticleAsync(updatedArticle);
            Snackbar.Add("Article mis à jour", Severity.Success);
            await LoadData();
        }
    }

    private async Task OnDeleteArticle(ArticlePdr article)
    {
        var result = await DialogService.ShowMessageBox(
            "Suppression",
            $"Voulez-vous vraiment supprimer l'article '{article.Designation}' ?",
            yesText: "Supprimer", cancelText: "Annuler");

        if (result == true)
        {
            await StockService.DeleteArticleAsync(article.Id);
            Snackbar.Add("Article supprimé", Severity.Success);
            await LoadData();
        }
    }

    private async Task ViewStockPdf()
    {
        var pdfBytes = await PdfService.GenerateStockStatePdfAsync(_articles);
        using var streamRef = new DotNetStreamReference(new MemoryStream(pdfBytes));
        await JSRuntime.InvokeVoidAsync("viewFileInNewTab", streamRef);
    }

    private Func<ArticlePdr, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.CodeArticle.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Designation.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.ReferenceConstructeur?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;

        return false;
    };
}
