@page "/"
@using Sahel.GMAO.Core.Constants
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Models
@inject IDtService DtService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@attribute [Authorize]

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold" Color="Color.Primary">Tableau de Bord</MudText>

<AuthorizeView>
    <Authorized>
        <MudGrid>
            @* DSI & BM View *@
            @if (context.User.IsInRole(AppRoles.DSI) || context.User.IsInRole(AppRoles.BM))
            {
                @* KPI Row *@
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center border-l-8 border-info" Elevation="4">
                        <MudIcon Icon="@Icons.Material.Filled.Input" Color="Color.Info" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@_stats.TotalDtThisMonth</MudText>
                            <MudText Typo="Typo.caption" Class="text-uppercase">Total DI ce mois</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center border-l-8 border-warning" Elevation="4">
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@_stats.PendingDt</MudText>
                            <MudText Typo="Typo.caption" Class="text-uppercase">DI à Traiter (BM)</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center border-l-8 border-success" Elevation="4">
                        <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Success" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@(_stats.TotalDtThisMonth - _stats.PendingDt)</MudText>
                            <MudText Typo="Typo.caption" Class="text-uppercase">OT en Exécution</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center border-l-8 border-primary" Elevation="4">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@_stats.RealizationRate.ToString("F1")%</MudText>
                            <MudText Typo="Typo.caption" Class="text-uppercase">Taux de Clôture</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="8">
                    <MudCard Elevation="4" Class="rounded-xl overflow-hidden">
                        <MudCardHeader Class="bg-light-grey">
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Flux de Maintenance (12 mois)</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (_stats.MonthlyActivities.Any())
                            {
                                <MudChart ChartType="ChartType.Line" 
                                          ChartSeries="@_series" 
                                          XAxisLabels="@_xAxisLabels" 
                                          Width="100%" 
                                          Height="300px" />
                            }
                            else
                            {
                                <div class="d-flex align-center justify-center" style="height: 300px;">
                                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                                </div>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudCard Elevation="4" Class="rounded-xl overflow-hidden">
                        <MudCardHeader Class="bg-light-grey">
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Dernières Alertes (Flux)</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudList T="string" Dense="true" Class="pa-0">
                                @foreach (var dt in _recentDts)
                                {
                                    <MudListItem Icon="@Icons.Material.Filled.Circle" 
                                                 IconColor="@GetStatusColor(dt.Statut)"
                                                 OnClick="@(() => NavManager.NavigateTo($"/demandes/{dt.Id}"))"
                                                 Class="mb-1 rounded-lg hover-bg-light">
                                        <div class="d-flex flex-column">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@dt.NumeroDT</MudText>
                                            <MudText Typo="Typo.caption" Class="text-truncate" Style="max-width: 200px;">@dt.TravailDemande</MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }

            @* Production View *@
            @if (context.User.IsInRole(AppRoles.Demandeur))
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-6 rounded-xl bg-gradient-orange text-white mb-6" Elevation="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Factory" Size="Size.Large" Class="mr-4" />
                            <div>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">Bienvenue @context.User.FindFirst("FullName")?.Value</MudText>
                                <MudText Typo="Typo.subtitle1">Espace Unité Production - Suivez vos demandes d'intervention</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard Elevation="4" Class="rounded-xl">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">1. Mes Demandes en Cours</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!_recentDts.Any(d => d.Statut < Sahel.GMAO.Core.Enums.StatutDT.Cloturee))
                            {
                                <MudAlert Severity="Severity.Normal" Variant="Variant.Outlined">Aucune demande en attente.</MudAlert>
                            }
                            else
                            {
                                <MudList T="string">
                                    @foreach (var dt in _recentDts.Where(d => d.Statut < Sahel.GMAO.Core.Enums.StatutDT.Cloturee).Take(5))
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.Assignment" OnClick="@(() => NavManager.NavigateTo($"/demandes/{dt.Id}"))">
                                            <div class="d-flex justify-space-between align-center">
                                                <MudText>@dt.NumeroDT - @dt.Equipement?.Code</MudText>
                                                <StatusBadge Statut="@dt.Statut" />
                                            </div>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.AddCircle" OnClick="@(() => NavManager.NavigateTo("/demandes"))">Émettre une DI</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }

            @* Maintenance View *@
            @if (context.User.IsInRole(AppRoles.Executant))
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-6 rounded-xl bg-gradient-red text-white mb-6" Elevation="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Large" Class="mr-4" />
                            <div>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">Salut @context.User.FindFirst("FullName")?.Value</MudText>
                                <MudText Typo="Typo.subtitle1">Équipe Maintenance - @_myTasksCount tâches vous attendent</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudCard Elevation="4" Class="rounded-xl">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Mes Ordres de Travail (OT)</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            @if (!_myTasks.Any())
                            {
                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">Excellent ! Toutes vos tâches sont terminées.</MudAlert>
                            }
                            else
                            {
                                <MudList T="DemandeTravail">
                                    @foreach (var task in _myTasks.Take(5))
                                    {
                                        <MudListItem OnClick="@(() => NavManager.NavigateTo($"/demandes/{task.Id}"))" 
                                                     Icon="@Icons.Material.Filled.PlayCircle" 
                                                     IconColor="Color.Info"
                                                     Text="@($"{task.NumeroDT} - {task.Equipement?.Code}")" />
                                    }
                                </MudList>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(() => NavManager.NavigateTo("/demandes"))">Voir ma liste complète</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }

            @* Magazin View *@
            @if (context.User.IsInRole(AppRoles.Magazin))
            {
                <MudItem xs="12">
                    <MudPaper Class="pa-6 rounded-xl bg-gradient-purple text-white mb-6" Elevation="6">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Class="mr-4" />
                            <div>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">Espace Magasin - @_stats.StockAlerts Alertes</MudText>
                                <MudText Typo="Typo.subtitle1">Gestion des Pièces de Rechange (PDR)</MudText>
                            </div>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Class="pa-6 rounded-xl d-flex align-center border-l-8 border-error" Elevation="4">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h4" Class="font-weight-bold">@_stats.StockAlerts</MudText>
                            <MudText Typo="Typo.subtitle2">Articles sous le seuil</MudText>
                        </div>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Class="pa-6 rounded-xl d-flex align-center border-l-8 border-info" Elevation="4" @onclick='() => NavManager.NavigateTo("/stock")' Style="cursor: pointer;">
                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Color="Color.Info" Size="Size.Large" Class="mr-4" />
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Gérer Stock</MudText>
                            <MudText Typo="Typo.caption">Accéder à l'inventaire</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </Authorized>
</AuthorizeView>

<style>
    .bg-light-grey { background-color: #f8f9fa; }
    .border-l-8 { border-left-width: 8px !important; }
    .bg-gradient-orange { background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%); }
    .bg-gradient-red { background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%); }
    .bg-gradient-purple { background: linear-gradient(135deg, #7B1FA2 0%, #4A148C 100%); }
    .hover-bg-light:hover { background-color: #f1f8e9; transition: background 0.3s; cursor: pointer; }
    .rounded-xl { border-radius: 16px !important; }
</style>

@code {
    private List<DemandeTravail> _myTasks = new();
    private List<DemandeTravail> _recentDts = new();
    private int _myTasksCount = 0;
    private DashboardStats _stats = new();
    private List<ChartSeries> _series = new();
    private string[] _xAxisLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var username = user.Identity?.Name ?? "";
        var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

        if (role == AppRoles.DSI || role == AppRoles.BM || role == AppRoles.Magazin)
        {
            _stats = await DtService.GetDashboardStatsAsync();
            
            if (role != AppRoles.Magazin)
            {
                var allDts = await DtService.GetAllAsync();
                _recentDts = allDts.OrderByDescending(d => d.DateEmission).Take(5).ToList();

                // Prepare chart data
                _series.Clear();
                _series.Add(new ChartSeries 
                { 
                    Name = "Interventions", 
                    Data = _stats.MonthlyActivities.Select(a => (double)a.Count).ToArray() 
                });
                _xAxisLabels = _stats.MonthlyActivities.Select(a => a.MonthName).ToArray();
            }
        }
        else if (role == AppRoles.Executant)
        {
            _myTasks = await DtService.GetForUserAsync(username, role, true);
            _myTasksCount = _myTasks.Count(d => d.Statut != Sahel.GMAO.Core.Enums.StatutDT.Cloturee);
        }
    }

    private Color GetStatusColor(Sahel.GMAO.Core.Enums.StatutDT statut) => statut switch
    {
        Sahel.GMAO.Core.Enums.StatutDT.EnAttente => Color.Info,
        Sahel.GMAO.Core.Enums.StatutDT.EnCours => Color.Warning,
        Sahel.GMAO.Core.Enums.StatutDT.Terminee => Color.Primary,
        Sahel.GMAO.Core.Enums.StatutDT.Cloturee => Color.Success,
        Sahel.GMAO.Core.Enums.StatutDT.Annulee => Color.Error,
        _ => Color.Default
    };
}
