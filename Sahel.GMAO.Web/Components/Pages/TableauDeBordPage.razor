@page "/"
@using Sahel.GMAO.Core.Constants
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Models
@inject IDtService DtService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@attribute [Authorize]

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold" Color="Color.Primary">Tableau de Bord</MudText>

<MudGrid>
    <AuthorizeView Roles="@AppRoles.DSI">
        <Authorized>
            @* KPI Row *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 rounded-lg d-flex align-center" Elevation="2">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Size="Size.Large" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6">@_stats.TotalDtThisMonth</MudText>
                        <MudText Typo="Typo.caption">Total DT ce mois</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 rounded-lg d-flex align-center" Elevation="2">
                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" Size="Size.Large" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6">@_stats.PendingDt</MudText>
                        <MudText Typo="Typo.caption">DT en cours</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 rounded-lg d-flex align-center" Elevation="2">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6">@_stats.StockAlerts</MudText>
                        <MudText Typo="Typo.caption">Alertes Stock</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 rounded-lg d-flex align-center" Elevation="2">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h6">@_stats.RealizationRate.ToString("F1")%</MudText>
                        <MudText Typo="Typo.caption">Taux de réalisation</MudText>
                    </div>
                </MudPaper>
            </MudItem>

            @* Charts placeholder *@
            <MudItem xs="12" md="8">
                <MudCard Elevation="2" Class="rounded-lg" Style="height: 400px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Activités de Maintenance (12 mois)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_stats.MonthlyActivities.Any())
                        {
                            <MudChart ChartType="ChartType.Bar" 
                                      ChartSeries="@_series" 
                                      XAxisLabels="@_xAxisLabels" 
                                      Width="100%" 
                                      Height="300px" />
                        }
                        else
                        {
                            <div class="d-flex align-center justify-center" style="height: 300px;">
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="rounded-lg" Style="height: 400px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Dernières DT</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string" Dense="true">
                            @foreach (var dt in _recentDts)
                            {
                                <MudListItem Icon="@Icons.Material.Filled.Circle" 
                                             IconColor="@GetStatusColor(dt.Statut)"
                                             OnClick="@(() => NavManager.NavigateTo($"/demandes/{dt.Id}"))">
                                    @dt.NumeroDT - @dt.TravailDemande
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="@AppRoles.Executant">
        <Authorized>
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-4">
                    Bienvenue @context.User.FindFirst("FullName")?.Value. Vous avez <strong>@_myTasksCount</strong> tâches assignées en attente.
                </MudAlert>
            </MudItem>
            
            <MudItem xs="12" md="6">
                <MudCard Elevation="2" Class="rounded-lg">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Mes Tâches Prioritaires</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_myTasks == null)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (!_myTasks.Any())
                        {
                            <MudText Typo="Typo.body2">Aucune tâche assignée pour le moment.</MudText>
                        }
                        else
                        {
                            <MudList T="DemandeTravail">
                                @foreach (var task in _myTasks.Take(5))
                                {
                                    <MudListItem OnClick="@(() => NavManager.NavigateTo($"/demandes/{task.Id}"))" 
                                                 Icon="@Icons.Material.Filled.Build" 
                                                 Text="@($"{task.NumeroDT} - {task.TravailDemande}")" />
                                }
                            </MudList>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => NavManager.NavigateTo("/demandes"))">Voir tout</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </Authorized>
    </AuthorizeView>
</MudGrid>

@code {
    private List<DemandeTravail> _myTasks = new();
    private List<DemandeTravail> _recentDts = new();
    private int _myTasksCount = 0;
    private DashboardStats _stats = new();
    private List<ChartSeries> _series = new();
    private string[] _xAxisLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var username = user.Identity?.Name ?? "";
        var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

        if (role == AppRoles.DSI)
        {
            _stats = await DtService.GetDashboardStatsAsync();
            var allDts = await DtService.GetAllAsync();
            _recentDts = allDts.OrderByDescending(d => d.DateEmission).Take(5).ToList();

            // Prepare chart data
            _series.Clear();
            _series.Add(new ChartSeries 
            { 
                Name = "Interventions", 
                Data = _stats.MonthlyActivities.Select(a => (double)a.Count).ToArray() 
            });
            _xAxisLabels = _stats.MonthlyActivities.Select(a => a.MonthName).ToArray();
        }
        else if (role == AppRoles.Executant)
        {
            _myTasks = await DtService.GetForUserAsync(username, role, true);
            _myTasksCount = _myTasks.Count(d => d.Statut != Sahel.GMAO.Core.Enums.StatutDT.Cloturee);
        }
    }

    private Color GetStatusColor(Sahel.GMAO.Core.Enums.StatutDT statut) => statut switch
    {
        Sahel.GMAO.Core.Enums.StatutDT.EnAttente => Color.Info,
        Sahel.GMAO.Core.Enums.StatutDT.EnCours => Color.Warning,
        Sahel.GMAO.Core.Enums.StatutDT.Terminee => Color.Primary,
        Sahel.GMAO.Core.Enums.StatutDT.Cloturee => Color.Success,
        Sahel.GMAO.Core.Enums.StatutDT.Annulee => Color.Error,
        _ => Color.Default
    };
}
