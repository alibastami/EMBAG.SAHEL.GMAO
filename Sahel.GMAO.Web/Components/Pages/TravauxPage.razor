@page "/travaux"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@inject IMaintenanceService MaintenanceService
@inject IPdfService PdfService
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Ordonnanceur")]

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold" Color="Color.Primary">Travaux de Maintenance</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Maintenance Préventive" Icon="@Icons.Material.Filled.BuildCircle">
        <MudDataGrid Items="@_preventives" Filterable="true" T="MaintenancePreventive">
            <Columns>
                <PropertyColumn Property="x => x.Equipement.Code" Title="Équipement" />
                <PropertyColumn Property="x => x.Operation" Title="Opération" />
                <PropertyColumn Property="x => x.FrequenceJours" Title="Fréquence (Jours)" />
                <PropertyColumn Property="x => x.DateProchaineEcheance" Title="Prochaine Échéance">
                    <CellTemplate>
                        <MudText Color="@GetEcheanceColor(context.Item.DateProchaineEcheance)">
                            @context.Item.DateProchaineEcheance.ToShortDateString()
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudTooltip Text="Valider Réalisation">
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" OnClick="@(() => ValiderRealisation(context.Item))" />
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>
    
    <MudTabPanel Text="Visites Périodiques" Icon="@Icons.Material.Filled.FactCheck">
        <MudAlert Severity="Severity.Info">Les visites périodiques réglementaires sont listées ici.</MudAlert>
        @* Logic similar to preventive but with specific regulatory focus *@
    </MudTabPanel>
</MudTabs>

@code {
    private List<MaintenancePreventive> _preventives = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _preventives = await MaintenanceService.GetAllPreventiveAsync();
    }

    private Color GetEcheanceColor(DateTime echeance)
    {
        if (echeance < DateTime.Today) return Color.Error;
        if (echeance < DateTime.Today.AddDays(7)) return Color.Warning;
        return Color.Default;
    }

    private async Task ValiderRealisation(MaintenancePreventive mp)
    {
        await MaintenanceService.RegisterRealizationAsync(mp.Id, DateTime.Now);
        await LoadData();
    }
}
