@page "/mes-taches/{id:int}"
@page "/mes-taches"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Enums
@using Sahel.GMAO.Web.Components.Dialogs
@using Sahel.GMAO.Web.Components.Shared
@inject IDtService DtService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IConsignationService ConsignationService
@inject IFabricationService FabricationService
@inject IDialogService DialogService
@attribute [Authorize(Roles = "Executant,DSI,BM")]

<MudText Typo="Typo.h4" Class="mb-2 font-weight-bold" Color="Color.Success">
    <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-3 mb-n1" />
    @(Id.HasValue ? $"3. Exécution OT : {_dt?.NumeroDT}" : "Mes Ordres de Travail (OT)")
</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-6" Color="Color.Secondary">Étape Maintenance : Réalisation des travaux et compte-rendu</MudText>

@if (!Id.HasValue)
{
    <MudAlert Severity="Severity.Info">Sélectionnez une demande de travail depuis la liste des tâches pour l'exécuter.</MudAlert>
    <!-- We can list tasks here, but user typically navigates from dashboard -->
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => NavigationManager.NavigateTo("/"))" Class="mt-4">Retour au Tableau de Bord</MudButton>
}
else if (_dt == null)
{
    @if (_loading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudAlert Severity="Severity.Error">Demande de travail introuvable ou vous n'avez pas l'autorisation d'y accéder.</MudAlert>
    }
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent>
                    <MudGrid>
                        @* Info Side *@
                        <MudItem xs="12" md="5">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Équipement</MudText>
                            <MudText Typo="Typo.body1" Class="mb-2"><b>@_dt.Equipement.Code</b> - @_dt.Equipement.Designation</MudText>
                            
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Organe / Partie</MudText>
                            <MudText Typo="Typo.body1" Class="mb-2">@_dt.OrganePartie</MudText>

                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Travail Demandé</MudText>
                            <MudPaper Elevation="0" Class="pa-2 bg-light mb-4">
                                <MudText Typo="Typo.body2">@_dt.TravailDemande</MudText>
                            </MudPaper>

                            <div class="mt-4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">CONSIGNATIONS / FABRICATIONS</MudText>
                                <div class="d-flex gap-2 mt-1">
                                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Lock" OnClick="CreateConsignation" Size="Size.Small">Consignation</MudButton>
                                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Build" OnClick="CreateFabrication" Size="Size.Small">Fabrication</MudButton>
                                </div>
                            </div>
                        </MudItem>

                        @* Execution Side *@
                        <MudItem xs="12" md="7">
                            <MudSelect T="StatutDT" Label="Statut de la DT" @bind-Value="_dt.Statut" Required="true" Variant="Variant.Outlined" Class="mb-4">
                                @foreach (StatutDT statut in Enum.GetValues(typeof(StatutDT)))
                                {
                                    <MudSelectItem Value="@statut">@statut.ToString()</MudSelectItem>
                                }
                            </MudSelect>

                            <div class="d-flex gap-2 mb-4">
                                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenAddLogDialog" StartIcon="@Icons.Material.Filled.History" FullWidth="true" Size="Size.Large">
                                    Nouveau Compte-Rendu
                                </MudButton>
                                <MudButton Color="Color.Info" Variant="Variant.Outlined" OnClick="OpenAddPdrDialog" StartIcon="@Icons.Material.Filled.AddShoppingCart" FullWidth="true">
                                    Consommer PDR
                                </MudButton>
                            </div>

                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Journal d'Intervention (Log)</MudText>
                            <div style="max-height: 250px; overflow-y: auto;" class="border rounded pa-2">
                                @if (_dt.JournalInterventions == null || !_dt.JournalInterventions.Any())
                                {
                                    <MudText Typo="Typo.caption" Class="pa-2 d-block">Aucun compte-rendu enregistré.</MudText>
                                }
                                else
                                {
                                    @foreach (var log in _dt.JournalInterventions.OrderByDescending(l => l.DateIntervention))
                                    {
                                        <div class="pa-2 mb-2 rounded border-l-4" style="border-left-color: var(--mud-palette-info); background-color: var(--mud-palette-background-grey);">
                                            <div class="d-flex justify-space-between mb-1">
                                                <MudText Typo="Typo.caption" Class="font-weight-bold">@log.DateIntervention.ToString("dd/MM HH:mm") - @log.Intervenant?.FullName</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">@log.DureeHeures H</MudChip>
                                            </div>
                                            <MudText Typo="Typo.body2">@log.TravailExecute</MudText>
                                        </div>
                                    }
                                }
                            </div>
                            
                            <MudDivider Class="my-4" />
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.subtitle1">
                                    Heures Totales : <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">@_myRole?.HeuresTravaillees H</MudChip>
                                </MudText>
                                <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="SaveDtInfo" StartIcon="@Icons.Material.Filled.CheckCircle" Size="Size.Large">
                                    3. Finaliser & Envoyer au BM
                                </MudButton>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private DemandeTravail? _dt;
    private InterventionRole? _myRole;
    private List<BonDeConsignation> _consignations = new();
    private List<DemandeFabrication> _fabrications = new();
    private bool _loading = true;
    private int _myUserId;
    
    // Binding helpers for nullable datetimes
    private DateTime? _dateDebut
    {
        get => _dt?.DateExecutionDebut;
        set { if (_dt != null) _dt.DateExecutionDebut = value; }
    }
    
    private DateTime? _dateFin
    {
        get => _dt?.DateExecutionFin;
        set { if (_dt != null) _dt.DateExecutionFin = value; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        if (int.TryParse(userIdStr, out var id))
        {
            _myUserId = id;
        }

        if (Id.HasValue)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        if (!Id.HasValue) return;
        _loading = true;
        _dt = await DtService.GetByIdAsync(Id.Value);
        
        if (_dt != null)
        {
            // Find my role in this DT
            _myRole = _dt.Intervenants.FirstOrDefault(r => r.IntervenantId == _myUserId);
            
            // If the technician is looking at this but hasn't been officially added yet by DSI,
            // we could auto-add them, or show an error. Let's auto-add if they are a technician to simplify for this demo.
            if (_myRole == null && _dt.Statut != StatutDT.Cloturee)
            {
                // Note: Real logic would require DSI to assign them, but we add if missing for testing.
                _myRole = new InterventionRole 
                { 
                    DemandeTravailId = _dt.Id, 
                    IntervenantId = _myUserId,
                    Qualification = "Intervenant",
                };
                
                // You'd typically save it via service here, but let's assume it gets saved when they save pointages
                _dt.Intervenants.Add(_myRole);
            }

            // Load linked docs
            _consignations = await ConsignationService.GetByDemandeIdAsync(Id.Value);
            // We'd need GetByDemandeIdAsync for Fabrication too, or filter
            var allFab = await FabricationService.GetAllAsync();
            _fabrications = allFab.Where(f => f.Intervenants.Any(i => i.NomsEtPrenoms.Contains(_dt.NumeroDT))).ToList(); 
            // In a real DB we'd have a FK. Let's assume we link by Observations for now if FK is missing in logic
        }
        
        _loading = false;
    }

    private async Task CreateConsignation()
    {
        if (_dt == null) return;
        var parameters = new DialogParameters
        { 
            { "DtId", _dt.Id }, 
            { "DtNumero", _dt.NumeroDT },
            { "EquipementId", _dt.EquipementId }
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ConsignationDialog>("Consignation", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }

    private async Task CreateFabrication()
    {
        if (_dt == null) return;
        var newDf = new DemandeFabrication 
        { 
            EquipementId = _dt.EquipementId, 
            DesignationPiece = $"Réparation pour DT {_dt.NumeroDT}",
            Observations = $"Lié à la Demande de Travail {_dt.NumeroDT}",
            Quantite = 1
        };
        await FabricationService.CreateAsync(newDf);
        Snackbar.Add("Demande de fabrication créée", Severity.Info);
        await LoadData();
    }



    private async Task SaveDtInfo()
    {
        if (_dt != null)
        {
            await DtService.UpdateAsync(_dt);
            Snackbar.Add("Statut et journal mis à jour.", Severity.Success);
        }
    }

    private void SavePointages()
    {
        // Pointages are now automatically saved via Intervention Logs
        Snackbar.Add("Les pointages sont maintenant automatiquement synchronisés via le Journal d'Intervention.", Severity.Info);
    }

    private async Task OpenAddLogDialog()
    {
        if (_dt == null) return;
        var parameters = new DialogParameters { ["DtId"] = _dt.Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddInterventionLogDialog>("Nouveau Compte-Rendu", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }

    private async Task OpenAddPdrDialog()
    {
        if (_dt == null) return;
        var parameters = new DialogParameters { ["DtId"] = _dt.Id };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddConsommableDialog>("Consommer PDR", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadData();
    }
}
