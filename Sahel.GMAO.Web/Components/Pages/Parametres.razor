@page "/parametres"
@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Web.Components.Dialogs
@inject INatureTravailService NatureService
@inject IWorkingProfileService ProfileService
@inject IBackupService BackupService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@attribute [Authorize(Roles = "DSI")]

<MudText Typo="Typo.h4" Class="mb-6 font-weight-bold" Color="Color.Primary">Configuration du Système</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Natures de Travail" Icon="@Icons.Material.Filled.Category">
        <MudDataGrid Items="@_natures" Hover="true" Loading="@_loadingNatures">
            <ToolBarContent>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OnAddNature" Class="mr-4">
                    Ajouter une Nature
                </MudButton>
                <MudSpacer />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.Nom" Title="Nom" />
                <PropertyColumn Property="x => x.Description" Title="Description" />
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudTooltip Text="Modifier">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OnEditNature(context.Item))" />
                        </MudTooltip>
                        <MudTooltip Text="Supprimer">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => OnDeleteNature(context.Item))" />
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>
    
    <MudTabPanel Text="Profils de Travail" Icon="@Icons.Material.Filled.Badge">
        <MudDataGrid Items="@_profiles" Hover="true" Loading="@_loadingProfiles">
            <ToolBarContent>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OnAddProfile" Class="mr-4">
                    Ajouter un Profil
                </MudButton>
                <MudSpacer />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Nom du Profil" />
                <PropertyColumn Property="x => x.Specialite" Title="Spécialité" />
                <PropertyColumn Property="x => x.HourlyRate" Title="Taux Horaire (DA/H)">
                    <CellTemplate>
                        @context.Item.HourlyRate.ToString("N2") DA
                    </CellTemplate>
                </PropertyColumn>
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudTooltip Text="Modifier">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="@(() => OnEditProfile(context.Item))" />
                        </MudTooltip>
                        <MudTooltip Text="Supprimer">
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => OnDeleteProfile(context.Item))" />
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudTabPanel>

    <MudTabPanel Text="Général" Icon="@Icons.Material.Filled.Settings">
        <MudText Typo="Typo.h6" Class="mb-4">Informations sur l'application</MudText>
        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Nom de l'entreprise" Value="@("EMBAG SAHEL")" ReadOnly="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Business" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Version" Value="@("v2.0.0-stable")" ReadOnly="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Info" />
                </MudItem>
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
                        Cette section permettra de configurer les seuils d'alerte et les paramètres de messagerie dans les futures versions.
                    </MudAlert>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudTabPanel>

    <MudTabPanel Text="Base de données & Sauvegarde" Icon="@Icons.Material.Filled.Storage">
        <MudText Typo="Typo.h6" Class="mb-4">Gestion des Données</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="pa-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Sauvegarde SQL (.bak)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Sauvegarde complète du serveur SQL.</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.Backup" Color="Color.Primary" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="_customBackupPath" Label="Dossier de destination (Optionnel)" Placeholder="Par défaut: dossier Backups" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">
                            Les fichiers sont stockés sur le serveur.
                        </MudAlert>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.CloudUpload" 
                                   OnClick="OnCreateBackup" 
                                   Disabled="@_isBackingUp" FullWidth="true">
                            @(_isBackingUp ? "EN COURS..." : "CRÉER SAUVEGARDE")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="pa-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Import / Restauration</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Restaurer la base depuis un fichier .bak</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.SettingsBackupRestore" Color="Color.Error" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                         <MudFileUpload T="IBrowserFile" FilesChanged="OnRestoreBackup" Accept=".bak">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.FileUpload"
                                           Disabled="@_isRestoring" FullWidth="true">
                                    @( _isRestoring ? "RESTAURATION..." : "IMPORTER & RESTAURER" )
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-4">
                            <b>Attention:</b> Toutes les données actuelles seront écrasées.
                        </MudAlert>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Class="pa-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Exportation SQLite (.db)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Format portable pour version nomade.</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.FileDownload" Color="Color.Tertiary" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Le fichier sera téléchargé via votre navigateur.
                        </MudAlert>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Tertiary" 
                                   StartIcon="@Icons.Material.Filled.FileDownload" 
                                   OnClick="OnExportToSqlite" 
                                   Disabled="@_isExporting" FullWidth="true">
                            @(_isExporting ? "EXPORT EN COURS..." : "TÉLÉCHARGER (.DB)")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>

@code {
    private List<WorkingProfile> _profiles = new();
    private bool _loadingProfiles = true;
    private List<NatureTravail> _natures = new();
    private bool _loadingNatures = true;
    private bool _isBackingUp = false;
    private bool _isExporting = false;
    private bool _isRestoring = false;
    private string _customBackupPath = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadNatures();
        await LoadProfiles();
    }

    private async Task LoadProfiles()
    {
        _loadingProfiles = true;
        _profiles = await ProfileService.GetAllAsync();
        _loadingProfiles = false;
    }

    private async Task OnAddProfile()
    {
        var parameters = new DialogParameters<WorkingProfileDialog>
        {
            { x => x.Profile, new WorkingProfile() },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<WorkingProfileDialog>("Nouveau Profil", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var profile = (WorkingProfile)result.Data!;
            await ProfileService.CreateAsync(profile);
            Snackbar.Add("Profil de travail créé", Severity.Success);
            await LoadProfiles();
        }
    }

    private async Task OnEditProfile(WorkingProfile profile)
    {
        var profileClone = new WorkingProfile
        {
            Id = profile.Id,
            Name = profile.Name,
            HourlyRate = profile.HourlyRate,
            Specialite = profile.Specialite
        };

        var parameters = new DialogParameters<WorkingProfileDialog>
        {
            { x => x.Profile, profileClone },
            { x => x.IsEdit, true }
        };

        var dialog = await DialogService.ShowAsync<WorkingProfileDialog>("Modifier le Profil", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var updatedProfile = (WorkingProfile)result.Data!;
            await ProfileService.UpdateAsync(updatedProfile);
            Snackbar.Add("Profil de travail mis à jour", Severity.Success);
            await LoadProfiles();
        }
    }

    private async Task OnDeleteProfile(WorkingProfile profile)
    {
        var result = await DialogService.ShowMessageBox(
            "Suppression",
            $"Voulez-vous vraiment supprimer le profil '{profile.Name}' ?",
            yesText: "Supprimer", cancelText: "Annuler");

        if (result == true)
        {
            await ProfileService.DeleteAsync(profile.Id);
            Snackbar.Add("Profil de travail supprimé", Severity.Success);
            await LoadProfiles();
        }
    }

    private async Task LoadNatures()
    {
        _loadingNatures = true;
        _natures = await NatureService.GetAllAsync();
        _loadingNatures = false;
    }

    private async Task OnAddNature()
    {
        var parameters = new DialogParameters<NatureTravailDialog>
        {
            { x => x.Nature, new NatureTravail() },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<NatureTravailDialog>("Nouvelle Nature", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var nature = (NatureTravail)result.Data!;
            await NatureService.CreateAsync(nature);
            Snackbar.Add("Nature de travail créée", Severity.Success);
            await LoadNatures();
        }
    }

    private async Task OnEditNature(NatureTravail nature)
    {
        var natureClone = new NatureTravail
        {
            Id = nature.Id,
            Nom = nature.Nom,
            Description = nature.Description
        };

        var parameters = new DialogParameters<NatureTravailDialog>
        {
            { x => x.Nature, natureClone },
            { x => x.IsEdit, true }
        };

        var dialog = await DialogService.ShowAsync<NatureTravailDialog>("Modifier la Nature", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            var updatedNature = (NatureTravail)result.Data!;
            await NatureService.UpdateAsync(updatedNature);
            Snackbar.Add("Nature de travail mise à jour", Severity.Success);
            await LoadNatures();
        }
    }

    private async Task OnDeleteNature(NatureTravail nature)
    {
        var result = await DialogService.ShowMessageBox(
            "Suppression",
            $"Voulez-vous vraiment supprimer la nature '{nature.Nom}' ?",
            yesText: "Supprimer", cancelText: "Annuler");

        if (result == true)
        {
            await NatureService.DeleteAsync(nature.Id);
            Snackbar.Add("Nature de travail supprimée", Severity.Success);
            await LoadNatures();
        }
    }

    private async Task OnCreateBackup()
    {
        _isBackingUp = true;
        try
        {
            var path = await BackupService.CreateBackupAsync(_customBackupPath);
            Snackbar.Add($"Sauvegarde réussie : {Path.GetFileName(path)}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors de la sauvegarde : {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBackingUp = false;
        }
    }

    private async Task OnRestoreBackup(IBrowserFile file)
    {
        if (file == null) return;
        
        var result = await DialogService.ShowMessageBox(
            "Confirmation de Restauration",
            $"Êtes-vous sûr de vouloir restaurer la base de données depuis '{file.Name}' ? Cette action est irréversible et écrasera toutes les données actuelles.",
            yesText: "Confirmer la Restauration", cancelText: "Annuler");

        if (result != true) return;

        _isRestoring = true;
        StateHasChanged();

        try
        {
            var tempPath = Path.Combine(Path.GetTempPath(), file.Name);
            using (var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 500)) 
            {
                using (var fileStream = File.Create(tempPath))
                {
                    await stream.CopyToAsync(fileStream);
                }
            }

            await BackupService.RestoreBackupAsync(tempPath);
            
            if (File.Exists(tempPath)) File.Delete(tempPath);

            Snackbar.Add("Base de données restaurée avec succès ! L'application va redémarrer.", Severity.Success);
            
            await Task.Delay(2000);
            await JS.InvokeVoidAsync("location.reload");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors de la restauration : {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRestoring = false;
            StateHasChanged();
        }
    }

    private async Task OnExportToSqlite()
    {
        _isExporting = true;
        try
        {
            var fileName = await BackupService.ExportToSqliteAsync();
            var filePath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Exports", fileName);
            
            if (File.Exists(filePath))
            {
                using var stream = File.OpenRead(filePath);
                using var streamRef = new DotNetStreamReference(stream);
                await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
                Snackbar.Add("Exportation réussie. Le téléchargement va commencer.", Severity.Success);
            }
            else
            {
                throw new Exception("Le fichier exporté est introuvable.");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors de l'exportation : {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }
}
