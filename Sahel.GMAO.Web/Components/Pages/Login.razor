@page "/login"
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Web.Auth
@using Sahel.GMAO.Core.Constants
@attribute [AllowAnonymous]
@layout Layout.AuthLayout
@inject IAuthService AuthService
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<div class="login-card">
    @* Logo Section *@
    <div class="d-flex flex-column align-center mb-6">
        @if (System.IO.File.Exists(System.IO.Path.Combine("wwwroot", "images", "gipec-logo-big.jpg")))
        {
            <img src="/images/gipec-logo-big.jpg" alt="GIPEC" width="200" class="mb-2" />
        }
        <span class="company-text">EPE EMBAG SPA</span>
    </div>

    @* Subtitle / Main Label *@
    <div class="text-center mb-8">
        <span class="app-subtitle">SAHEL GMAO</span>
    </div>

    @* Form *@
    <MudForm @ref="_form" @bind-IsValid="@_success">
        <MudTextField T="string" 
                      @bind-Value="_username" 
                      Label="Nom d'utilisateur" 
                      Variant="Variant.Outlined" 
                      FullWidth="true"
                      Margin="Margin.Dense"
                      ShrinkLabel="true"
                      Class="mb-4" />

        <MudTextField T="string" 
                      @bind-Value="_password" 
                      Label="Mot de passe" 
                      InputType="@_passwordType"
                      Variant="Variant.Outlined" 
                      FullWidth="true"
                      Margin="Margin.Dense"
                      ShrinkLabel="true"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      Class="mb-6" />
        
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   Size="Size.Large" 
                   FullWidth="true" 
                   ButtonType="ButtonType.Button"
                   OnClick="LoginAsync" 
                   Disabled="@_loading">
            @if (_loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">CONNEXION...</MudText>
            }
            else
            {
                <MudText>SE CONNECTER</MudText>
            }
        </MudButton>

        @if (_showError)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mt-4">
                Identifiants incorrects. Veuillez réessayer.
            </MudAlert>
        }
    </MudForm>
</div>

<style>
    .login-card {
        max-width: 380px;
        width: 100%;
        margin: auto;
        padding: 44px 32px;
        background: #FFFFFF;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(27,94,32,0.25);
        border: 1px solid #C8E6C9;
    }

    .company-text {
        font-size: 22px;
        font-weight: 900;
        color: #1B5E20;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .app-subtitle {
        font-size: 15px;
        color: #558B2F;
        font-weight: 600;
        display: block;
        text-align: center;
    }
</style>

@code {
    private MudForm _form = default!;
    private bool _success;
    private bool _loading = false;
    private bool _showError = false;
    private string _username = "";
    private string _password = "";

    private InputType _passwordType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (_passwordType == InputType.Password)
        {
            _passwordType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            _passwordType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private async Task LoginAsync()
    {
        _showError = false;
        await _form.Validate();
        if (!_success) return;

        _loading = true;
        try
        {
            var user = await AuthService.AuthenticateAsync(_username, _password);
            if (user != null)
            {
                await AuthStateProvider.MarkUserAsAuthenticated(user);
                
                // Redirect based on role
                if (user.Role == AppRoles.DSI)
                    NavManager.NavigateTo("/");
                else
                    NavManager.NavigateTo("/"); // Both start at dashboard/dashboard for now
            }
            else
            {
                _showError = true;
            }
        }
        catch (Exception ex)
        {
            _showError = true;
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
