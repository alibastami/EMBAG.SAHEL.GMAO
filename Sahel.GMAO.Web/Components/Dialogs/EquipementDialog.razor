@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Equipement.Id == 0 ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @(Equipement.Id == 0 ? "Ajouter un Équipement" : "Modifier l'Équipement")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Code" @bind-Value="Equipement.Code" Required="true" RequiredError="Le code est requis" Placeholder="e.g., P-101" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Désignation" @bind-Value="Equipement.Designation" Required="true" RequiredError="La désignation est requise" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Marque" @bind-Value="Equipement.Marque" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Modèle" @bind-Value="Equipement.Modele" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Section" @bind-Value="Equipement.Section" Required="true" RequiredError="La section est requise">
                        <MudSelectItem Value="@("OFFSET")">OFFSET</MudSelectItem>
                        <MudSelectItem Value="@("FAÇONNAGE")">FAÇONNAGE</MudSelectItem>
                        <MudSelectItem Value="@("MAINTENANCE")">MAINTENANCE</MudSelectItem>
                        <MudSelectItem Value="@("SERVICES TECHNIQUES")">SERVICES TECHNIQUES</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="N° de Série" @bind-Value="Equipement.NumeroSerie" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Caractéristiques Techniques" @bind-Value="Equipement.CaracteristiquesTechniques" Lines="3" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="Equipement.IsActive" Label="Actif" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success)">Enregistrer</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Equipement Equipement { get; set; } = new();
    [Inject] private IEquipementService EquipementService { get; set; } = default!;

    private MudForm _form = default!;
    private bool _success;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            try
            {
                if (Equipement.Id == 0)
                    await EquipementService.CreateAsync(Equipement);
                else
                    await EquipementService.UpdateAsync(Equipement);

                Snackbar.Add("Enregistrement réussi", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur: {ex.Message}", Severity.Error);
            }
        }
    }
}
