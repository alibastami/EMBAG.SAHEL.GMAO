@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@inject IStockService StockService
@inject IDtService DtService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Consommer une Pièce de Rechange (PDR)</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="int" Label="Article PDR" Value="_selectedArticleId" ValueChanged="OnArticleSelected" Required="true" Variant="Variant.Outlined">
                        @foreach (var art in _articles)
                        {
                            <MudSelectItem Value="@art.Id">@art.CodeArticle - @art.Designation (@art.QuantiteEnStock @art.Unite)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="double" Label="Quantité" @bind-Value="_quantite" Required="true" Variant="Variant.Outlined" Min="0.1" />
                </MudItem>
                @if (_userRole != Sahel.GMAO.Core.Constants.AppRoles.Executant)
                {
                    <MudItem xs="6">
                        <MudNumericField T="decimal" Label="Prix Unitaire (DA)" @bind-Value="_prixUnitaire" Required="true" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                }
                <MudItem xs="6">
                    <MudTextField Label="N° BSM" @bind-Value="_nBsm" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Observation" @bind-Value="_observation" Variant="Variant.Outlined" Lines="2" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Consommer</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int DtId { get; set; }

    private MudForm _form = null!;
    private List<ArticlePdr> _articles = new();
    private int _selectedArticleId;
    private double _quantite = 1;
    private decimal _prixUnitaire;
    private string? _nBsm;
    private string? _observation;
    private string _userRole = "";

    private void OnArticleSelected(int id)
    {
        _selectedArticleId = id;
        var art = _articles.FirstOrDefault(a => a.Id == id);
        if (art != null) _prixUnitaire = art.PrixUnitaire;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
        
        _articles = await StockService.GetAllAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid)
        {
            var article = _articles.FirstOrDefault(a => a.Id == _selectedArticleId);
            if (article != null && article.QuantiteEnStock < _quantite)
            {
                Snackbar.Add("Stock insuffisant !", Severity.Warning);
                return;
            }

            try
            {
                await DtService.AddConsommableAsync(DtId, _selectedArticleId, _quantite, _prixUnitaire, _nBsm, _observation);
                Snackbar.Add("Pièce consommée avec succès", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur: {ex.Message}", Severity.Error);
            }
        }
    }
}
