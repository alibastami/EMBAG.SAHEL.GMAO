@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@using Sahel.GMAO.Core.Enums
@using Sahel.GMAO.Core.Constants
@inject ISnackbar Snackbar
@inject IAuthService AuthService
@inject IDtService DtService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Color="Color.Success" Class="mr-3 mb-n1" />
            2. Création de l'Ordre de Travail (OT)
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">Assigner un technicien à la demande <b>@Dt.NumeroDT</b> (@Dt.Equipement.Code)</MudText>
        
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudSelect T="User" Label="Sélectionner le technicien" Value="_selectedTechnicien" ValueChanged="OnTechnicianChanged" Required="true" RequiredError="Veuillez choisir un technicien" Variant="Variant.Outlined">
                @foreach (var tech in _techniciens)
                {
                    <MudSelectItem Value="@tech">@tech.FullName (@(tech.WorkingProfile?.Name ?? tech.Role))</MudSelectItem>
                }
            </MudSelect>

            <MudGrid Class="mt-4">
                <MudItem xs="8">
                    <MudNumericField T="decimal" Label="Taux (DA)" @bind-Value="_tauxHoraire" Required="true" Variant="Variant.Outlined" Min="0" Adornment="Adornment.End" AdornmentText="DA" />
                </MudItem>
                <MudItem xs="4">
                    <MudSelect T="LaborUnit" Label="Unité" @bind-Value="_unit" Variant="Variant.Outlined">
                        @foreach (LaborUnit unit in Enum.GetValues(typeof(LaborUnit)))
                        {
                            <MudSelectItem Value="@unit">@unit.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success)">Lancer l'Ordre de Travail (OT)</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DemandeTravail Dt { get; set; } = default!;
    
    private List<User> _techniciens = new();
    private User? _selectedTechnicien;
    private decimal _tauxHoraire = 500;
    private LaborUnit _unit = LaborUnit.Heure;
    
    private MudForm _form = default!;
    private bool _success;

    protected override async Task OnInitializedAsync()
    {
        var allUsers = await AuthService.GetAllUsersAsync();
        // Ensure we have profiles for rates
        _techniciens = allUsers.Where(u => u.Role == AppRoles.Executant || u.Role == AppRoles.DSI).ToList();
    }

    private void OnTechnicianChanged(User user)
    {
        _selectedTechnicien = user;
        if (user != null)
        {
            // Set rate from profile if available
            _tauxHoraire = user.WorkingProfile?.HourlyRate ?? 500;
            _unit = user.WorkingProfile?.Unit ?? LaborUnit.Heure;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (_form.IsValid && _selectedTechnicien != null)
        {
            try
            {
                // Add as intervenant (assignment)
                await DtService.AddIntervenantAsync(Dt.Id, _selectedTechnicien.Id, 0, _selectedTechnicien.Position, _tauxHoraire, _unit);
                
                // Update status to EnCours
                await DtService.UpdateStatusAsync(Dt.Id, StatutDT.EnCours);

                Snackbar.Add($"DT assignée à {_selectedTechnicien.FullName}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur: {ex.Message}", Severity.Error);
            }
        }
    }
}
