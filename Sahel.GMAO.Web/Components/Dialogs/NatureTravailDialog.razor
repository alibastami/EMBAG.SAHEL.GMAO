@using Sahel.GMAO.Core.Entities
@using Sahel.GMAO.Core.Interfaces
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-3 mb-n1" />
            @(IsEdit ? "Modifier la Nature de Travail" : "Nouvelle Nature de Travail")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Nom" @bind-Value="Nature.Nom" Required="true" RequiredError="Le nom est requis" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Description" @bind-Value="Nature.Description" Lines="3" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_success)">Enregistrer</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public NatureTravail Nature { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private bool _success;
    private MudForm _form = null!;

    void Cancel() => MudDialog.Cancel();

    void Submit()
    {
        MudDialog.Close(DialogResult.Ok(Nature));
    }
}
